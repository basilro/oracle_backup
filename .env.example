WEB_PORT=8088
WEB_ADMIN_USER=admin
# 로그인 비밀번호 설정 방법 (택1):
#  1) 아래 WEB_ADMIN_PASSWORD 에 평문 입력 → 부팅 시 bcrypt 해시로 변환·영속화.
#     (주의: 평문 env는 docker inspect 로 보임. 첫 부팅 후 이 줄을 지워도 로그인 유지됨)
#  2) 비워두면 첫 부팅 시 랜덤 비밀번호를 생성해 컨테이너 로그에 1회 출력.
#  3) 더 안전: secrets/web-admin.hash 에 bcrypt 해시를 직접 넣으면 그게 최우선.
WEB_ADMIN_PASSWORD=
REMOTE_NAME=gdrive
HOST_TAG=myhost
ALLOW_REPO_INIT=false
