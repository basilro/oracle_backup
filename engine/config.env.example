KEEP_DAILY=7
UPLOAD_LIMIT_KBPS=5120
BACKUP_SCHEDULE="0 3 * * *"
CHECK_SCHEDULE="0 4 * * 0"
SCHEDULER_ENABLED=false
DB_BACKUP_ENABLED=true
DB_DUMP_MIN_FREE_MB=5000
PG_CONTAINER=postgres
PG_USER=postgres
MONGO_CONTAINER=mongodb
REDIS_CONTAINER=redis
REDIS_DUMP_PATH=/data/dump.rdb
# 백업 소스 경로(공백 구분, 기본 /home). /var/lib/docker/volumes 는 항상 포함됩니다.
# UI(설정 탭)에서 바꾸면 /config/source-paths 파일로 저장되며 이 env보다 우선합니다.
SOURCE_PATHS=/home
STAGING_ROOT=/home/docker/_backup_staging
